---
---
<header class="fixed top-0 left-0 w-full z-[100] bg-[#070b12]/85 backdrop-blur-md border-b border-emerald-500/15">
    <nav class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center relative">
        
        <!-- Logo Laputa Core -->
        <a href="/" data-astro-reload class="flex items-center gap-3 group relative z-[100]">
            <div class="relative flex items-center justify-center w-6 h-6">
                <span class="absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-30 animate-ping"></span>
                <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-cyan-400 shadow-[0_0_12px_#06b6d4]"></span>
            </div>
            <span class="font-mono font-bold text-white tracking-widest text-sm uppercase">IJM<span class="text-emerald-500">.core</span></span>
        </a>
        
        <!-- Menu Desktop -->
        <ul class="hidden md:flex items-center space-x-10 text-xs font-mono tracking-[0.2em] text-zinc-400 relative z-[100]">
            <li><a href="/" data-astro-reload class="hover:text-cyan-400 transition-all cursor-pointer block py-2">> BERANDA</a></li>
            <li><a href="/galeri" data-astro-reload class="hover:text-emerald-400 transition-all cursor-pointer block py-2">> GALERI</a></li>
        </ul>

        <!-- Tombol Hamburger -->
        <button id="menu-toggle" class="md:hidden text-white z-[100] relative p-2 cursor-pointer">
            <svg id="hamburger-icon" class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path id="path-menu" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/>
            </svg>
        </button>

        <!-- Menu Drawer -->
        <div id="mobile-menu" class="absolute top-full left-0 w-full bg-[#0a1118]/95 backdrop-blur-xl border-b border-emerald-500/20 hidden flex-col z-[90] shadow-2xl">
            <a href="/" data-astro-reload class="mobile-link px-6 py-6 text-xl font-mono text-white hover:bg-white/5 border-b border-white/5 transition-all flex items-center gap-3 cursor-pointer">
                > BERANDA
            </a>
            <a href="/galeri" data-astro-reload class="mobile-link px-6 py-6 text-xl font-mono text-white hover:bg-white/5 border-b border-white/5 transition-all flex items-center gap-3 cursor-pointer">
                > GALERI
            </a>
        </div>
    </nav>
</header>

<script is:inline>
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const pathMenu = document.getElementById('path-menu');
    let isOpen = false;

    if (menuToggle) {
        menuToggle.addEventListener('click', (e) => {
            e.stopPropagation();
            isOpen = !isOpen;
            mobileMenu.classList.toggle('hidden');
            mobileMenu.classList.toggle('flex');
            pathMenu.setAttribute('d', isOpen ? 'M6 18L18 6M6 6l12 12' : 'M4 6h16M4 12h16m-7 6h7');
        });
    }
</script>