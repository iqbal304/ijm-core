---
---
<div class="bg-[#080d1a]/80 border border-emerald-500/20 p-3.5 rounded-2xl backdrop-blur-md relative overflow-hidden group w-full h-full flex flex-col shadow-[0_0_30px_rgba(0,0,0,0.6)] hover:border-cyan-400/40 transition-colors duration-500">
    
    <!-- HUD Overlay Global Telemetry -->
    <div class="absolute top-6 right-6 z-40 bg-[#030508]/90 backdrop-blur-md px-3 py-1.5 rounded border border-emerald-500/30 text-[9px] font-mono text-emerald-400 shadow-lg flex items-center gap-2">
        <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
        GLOBAL_TELEMETRY: ACTIVE
    </div>
    
    <!-- Canvas Jaringan Data Pipeline -->
    <canvas id="network-canvas" class="absolute inset-0 w-full h-full opacity-35 pointer-events-none z-0"></canvas>

    <div id="earthquake-map" class="w-full h-70 lg:h-95 rounded-xl bg-[#030508] z-10 grayscale-[30%] group-hover:grayscale-0 transition-all duration-1000 grow border border-emerald-500/15"></div>
</div>

<script>
    import L from 'leaflet';
    
    const canvas = document.getElementById('network-canvas') as HTMLCanvasElement;
    const ctx = canvas?.getContext('2d');
    let particles: any[] = [];
    
    function initParticles() {
        if (!canvas) return;
        canvas.width = canvas.offsetWidth || 500;
        canvas.height = canvas.offsetHeight || 300;
        particles = [];
        for (let i = 0; i < 35; i++) {
            particles.push({
                x: Math.random() * canvas.width,
                y: Math.random() * canvas.height,
                vx: (Math.random() - 0.5) * 0.4,
                vy: (Math.random() - 0.5) * 0.4
            });
        }
    }

    function drawNetwork() {
        if (!ctx || !canvas) return;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.strokeStyle = 'rgba(6, 182, 212, 0.25)'; /* Cyber Cyan Line */
        ctx.lineWidth = 1;

        particles.forEach((p, i) => {
            p.x += p.vx; p.y += p.vy;
            if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
            if (p.y < 0 || p.y > canvas.height) p.vy *= -1;

            ctx.beginPath();
            ctx.arc(p.x, p.y, 1.5, 0, Math.PI * 2);
            ctx.fillStyle = '#10b981'; /* Emerald Dot */
            ctx.fill();

            for (let j = i + 1; j < particles.length; j++) {
                const dist = Math.hypot(p.x - particles[j].x, p.y - particles[j].y);
                if (dist < 110) {
                    ctx.beginPath();
                    ctx.moveTo(p.x, p.y);
                    ctx.lineTo(particles[j].x, particles[j].y);
                    ctx.stroke();
                }
            }
        });
        requestAnimationFrame(drawNetwork);
    }

    if (typeof window !== 'undefined') {
        const mapElement = document.getElementById('earthquake-map');
        if (mapElement && !(mapElement as any)._leaflet_id) {
            setTimeout(() => {
                initParticles();
                drawNetwork();
            }, 100);

            const map = L.map('earthquake-map', { zoomControl: false, attributionControl: false }).setView([0, 120], 3); 
            L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {}).addTo(map);

            fetch('https://earthquake.usgs.gov/fdsnws/event/1/query?format=geojson&limit=20&minmagnitude=4.5')
                .then(res => res.json())
                .then(data => {
                    data.features.forEach((q: any) => {
                        const coords = [q.geometry.coordinates[1], q.geometry.coordinates[0]];
                        L.circle(coords as [number, number], {
                            radius: q.properties.mag * 20000, 
                            color: '#10b981', /* Terminal Green Border */
                            fillColor: '#06b6d4', /* Cyan Fill */
                            fillOpacity: 0.45, 
                            weight: 1.5
                        }).addTo(map);
                    });
                })
                .catch(err => console.error("Gagal mengambil data USGS:", err));
        }
    }
</script>