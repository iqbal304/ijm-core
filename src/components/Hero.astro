---
---
<section id="hero-section" class="min-h-screen flex flex-col xl:flex-row items-center justify-between relative z-20 pt-24 pb-10">
    
    <div class="w-full xl:w-1/2 flex flex-col justify-center text-left relative z-30">
        
        <div class="hero-item mb-8 relative group w-max">
            <div class="absolute -inset-1 bg-gradient-to-r from-violet-500 to-sky-500 rounded-2xl blur opacity-30 group-hover:opacity-70 transition duration-1000 group-hover:duration-200"></div>
            
            <div class="absolute -top-1 -left-1 w-3 h-3 border-t-2 border-l-2 border-sky-400 z-20 transition-all group-hover:-top-2 group-hover:-left-2"></div>
            <div class="absolute -top-1 -right-1 w-3 h-3 border-t-2 border-r-2 border-violet-400 z-20 transition-all group-hover:-top-2 group-hover:-right-2"></div>
            <div class="absolute -bottom-1 -left-1 w-3 h-3 border-b-2 border-l-2 border-sky-400 z-20 transition-all group-hover:-bottom-2 group-hover:-left-2"></div>
            <div class="absolute -bottom-1 -right-1 w-3 h-3 border-b-2 border-r-2 border-violet-400 z-20 transition-all group-hover:-bottom-2 group-hover:-right-2"></div>

            <div class="relative flex items-center gap-4 bg-[#02000a] border border-white/10 p-2 rounded-2xl z-10">
                <img src="/foto-iqbal.jpg" alt="Iqbal Jabar" class="w-16 h-16 rounded-xl object-cover grayscale group-hover:grayscale-0 transition-all duration-500" />
                <div class="pr-4">
                    <h3 class="text-white font-bold text-sm flex items-center gap-2">
                        Iqbal Jabar Marjan
                        <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse" title="Life Sign Detected"></span>
                    </h3>
                    <p class="text-[10px] font-mono text-sky-400 tracking-widest uppercase">KAPTEN / LEAD ARCHITECT</p>
                </div>
            </div>
        </div>
        
        <h1 class="hero-item scramble-text text-5xl sm:text-7xl lg:text-8xl font-extrabold text-white mb-6 tracking-tighter leading-[0.9] text-glow-violet drop-shadow-2xl" data-target="Iqbal Marjan">
            Iqbal Marjan
        </h1>
        
        <h2 class="hero-item text-xl sm:text-3xl font-light text-zinc-400 mb-8 leading-relaxed border-l border-white/10 pl-6">
            <span class="font-bold text-white">Backend</span> adalah <span class="italic text-violet-400">Gaya Gravitasi.</span><br/>
            <span class="font-bold text-white">Frontend</span> adalah <span class="italic text-sky-400">Rasi Bintang.</span>
        </h2>
        
        <div class="hero-item relative w-full max-w-lg mt-4 bg-[#02000a]/40 backdrop-blur-xl border border-white/10 rounded-xl p-5 shadow-[0_0_30px_rgba(14,165,233,0.05)] overflow-hidden group hover:border-sky-500/30 transition-colors duration-500">
            
            <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-sky-400 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

            <div class="flex items-center justify-between border-b border-white/10 pb-3 mb-4">
                <span class="text-[10px] font-mono text-sky-400 tracking-[0.2em] uppercase flex items-center gap-2">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"></path></svg>
                    Sys.Telemetry_Data
                </span>
                <div class="flex gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse shadow-[0_0_5px_#10b981]"></span>
                    <span class="w-2 h-2 rounded-full bg-violet-500 animate-pulse shadow-[0_0_5px_#8b5cf6]" style="animation-delay: 0.5s;"></span>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-5 font-mono text-xs text-zinc-400">
                <div class="flex flex-col gap-1.5">
                    <span class="text-[9px] text-zinc-500 tracking-widest">CORE_ENGINE</span>
                    <span class="text-white font-bold">Astro v4.0 <span class="text-emerald-400 text-[10px] font-normal ml-1">[STABIL]</span></span>
                </div>
                <div class="flex flex-col gap-1.5">
                    <span class="text-[9px] text-zinc-500 tracking-widest">GRAVITY_DRIVE</span>
                    <span class="text-white font-bold text-glow-violet">Node.js / API</span>
                </div>
                <div class="flex flex-col gap-2 col-span-2 mt-1">
                    <div class="flex justify-between text-[9px] tracking-widest">
                        <span>FRONTEND_SYNC</span>
                        <span class="text-sky-400">100%</span>
                    </div>
                    <div class="w-full h-1 bg-white/10 rounded-full overflow-hidden">
                        <div class="h-full bg-gradient-to-r from-violet-500 to-sky-400 w-full shadow-[0_0_10px_#0ea5e9]"></div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="w-full xl:w-1/2 flex justify-center items-center mt-20 xl:mt-0 relative hero-item min-h-[300px] lg:min-h-[500px]">
        
        <div class="absolute w-[300px] h-[300px] sm:w-[450px] sm:h-[450px] rounded-full border border-white/10 animate-[spin_20s_linear_infinite_reverse] flex items-center justify-center pointer-events-none">
            <div class="absolute -top-3 bg-[#02000a] border border-sky-500/50 text-sky-400 text-[9px] px-3 py-1 rounded-full font-mono">ASTRO.JS</div>
            <div class="absolute -bottom-3 bg-[#02000a] border border-violet-500/50 text-violet-400 text-[9px] px-3 py-1 rounded-full font-mono">GSAP_ENGINE</div>
            <div class="absolute -left-3 bg-[#02000a] border border-emerald-500/50 text-emerald-400 text-[9px] px-3 py-1 rounded-full font-mono">TAILWIND_CSS</div>
        </div>

        <div class="absolute w-[220px] h-[220px] sm:w-[350px] sm:h-[350px] rounded-full border border-white/5 animate-[spin_15s_linear_infinite] flex items-center justify-center">
            <span class="absolute -top-3 text-[10px] sm:text-xs font-mono text-violet-400 tracking-widest bg-[#02000a] px-3 border border-violet-500/30 rounded-full">STRUCTURAL LOGIC</span>
        </div>

        <div class="absolute w-[180px] h-[180px] sm:w-[280px] sm:h-[280px] rounded-full border-2 border-t-violet-500 border-r-sky-400 border-b-transparent border-l-transparent animate-[spin_10s_linear_infinite_reverse] blur-[3px]"></div>

        <div id="black-hole" class="relative w-[140px] h-[140px] sm:w-[200px] sm:h-[200px] rounded-full bg-black shadow-[0_0_50px_15px_rgba(0,0,0,1),inset_0_0_30px_rgba(139,92,246,0.6)] border border-white/5 z-10 flex items-center justify-center overflow-hidden cursor-crosshair">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_30%,rgba(0,0,0,1)_80%)] animate-pulse"></div>
            <span class="font-mono text-[10px] text-zinc-600 tracking-[0.5em] z-20 mix-blend-screen">SINGULARITY</span>
        </div>
    </div>
</section>

<script is:inline>
    // Membungkus semuanya dalam fungsi aman untuk menghindari bentrok
    (function initHeroSection() {
        document.addEventListener("DOMContentLoaded", () => {
            
            // 1. SCRAMBLE TEXT EFFECT
            const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&*";
            const scrambleElements = document.querySelectorAll('.scramble-text');
            
            scrambleElements.forEach(el => {
                const target = el.getAttribute('data-target');
                if (!target) return; // Fail-safe
                
                let iteration = 0;
                const interval = setInterval(() => {
                    el.innerText = target.split("").map((letter, index) => {
                        if(index < iteration) return target[index];
                        return chars[Math.floor(Math.random() * chars.length)];
                    }).join("");
                    if(iteration >= target.length) clearInterval(interval);
                    iteration += 1 / 3; 
                }, 30);
            });

            // 2. BLACK HOLE HOVER EFFECT (Pengecekan GSAP sebelum dieksekusi)
            const heroSection = document.getElementById('hero-section');
            const blackHole = document.getElementById('black-hole');

            if(heroSection && blackHole && typeof window.gsap !== 'undefined') {
                heroSection.addEventListener('mousemove', (e) => {
                    const rect = heroSection.getBoundingClientRect();
                    const x = (e.clientX - rect.left - rect.width/2) * 0.08;
                    const y = (e.clientY - rect.top - rect.height/2) * 0.08;
                    window.gsap.to(blackHole, { x: x, y: y, duration: 0.6, ease: "power2.out" });
                });
                heroSection.addEventListener('mouseleave', () => {
                    window.gsap.to(blackHole, { x: 0, y: 0, duration: 1.5, ease: "elastic.out(1, 0.3)" });
                });
            }
        });
    })();
</script>