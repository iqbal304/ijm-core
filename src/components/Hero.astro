---
---
<section id="hero-section" class="min-h-screen flex flex-col xl:flex-row items-center justify-between relative z-20 pt-24 pb-10">
    
    <!-- BAGIAN KIRI: Teks & Manuskrip Log -->
    <div class="w-full xl:w-1/2 flex flex-col justify-center text-left relative z-30">
        
        <!-- Profile Badge -->
        <div class="hero-item mb-8 relative group w-max">
            <div class="absolute -inset-1 bg-gradient-to-r from-amber-500 to-teal-500 rounded-2xl blur opacity-30 group-hover:opacity-70 transition duration-1000 group-hover:duration-200"></div>
            
            <div class="absolute -top-1 -left-1 w-3 h-3 border-t-2 border-l-2 border-amber-400 z-20 transition-all group-hover:-top-2 group-hover:-left-2"></div>
            <div class="absolute -top-1 -right-1 w-3 h-3 border-t-2 border-r-2 border-teal-400 z-20 transition-all group-hover:-top-2 group-hover:-right-2"></div>
            <div class="absolute -bottom-1 -left-1 w-3 h-3 border-b-2 border-l-2 border-amber-400 z-20 transition-all group-hover:-bottom-2 group-hover:-left-2"></div>
            <div class="absolute -bottom-1 -right-1 w-3 h-3 border-b-2 border-r-2 border-teal-400 z-20 transition-all group-hover:-bottom-2 group-hover:-right-2"></div>

            <div class="relative flex items-center gap-4 bg-[#060913] border border-amber-500/20 p-2 rounded-2xl z-10">
                <img src="/foto-iqbal.jpg" alt="Iqbal Jabar" class="w-16 h-16 rounded-xl object-cover grayscale group-hover:grayscale-0 transition-all duration-500 border border-amber-500/30" />
                <div class="pr-4">
                    <h3 class="text-white font-bold text-sm flex items-center gap-2">
                        Iqbal Jabar Marjan
                        <span class="w-2 h-2 bg-amber-400 rounded-full animate-ping" title="Sacred Logic Active"></span>
                    </h3>
                    <p class="text-[10px] font-mono text-teal-400 tracking-widest uppercase">ARSITEK ALGORITMA // IJM.CORE</p>
                </div>
            </div>
        </div>
        
        <!-- Main Heading -->
        <h1 class="hero-item scramble-text text-5xl sm:text-7xl lg:text-8xl font-extrabold text-white mb-6 tracking-tighter leading-[0.9] text-glow-amber drop-shadow-2xl" data-target="Iqbal Marjan">
            Iqbal Marjan
        </h1>
        
        <!-- Subheading Filosofis Islamic Golden Age -->
        <h2 class="hero-item text-lg sm:text-2xl font-light text-zinc-300 mb-8 leading-relaxed border-l-2 border-amber-500/40 pl-6">
            <span class="font-bold text-white">Backend</span> adalah <span class="font-semibold text-amber-400 text-glow-amber">Al-Jabr (Logika)</span> yang menyeimbangkan sistem.<br/>
            <span class="font-bold text-white">Frontend</span> adalah <span class="italic text-teal-400 text-glow-teal">Geometri Suci</span> yang memukau penglihatan.
        </h2>
        
        <!-- Kitab Al-Jabr Codex (Telemetry HUD Anti-Bug) -->
        <div class="hero-item relative w-full max-w-lg mt-4 bg-[#080d1a]/60 backdrop-blur-xl border border-amber-500/20 rounded-xl p-5 shadow-[0_0_30px_rgba(245,158,11,0.08)] overflow-hidden group hover:border-teal-500/40 transition-colors duration-500">
            
            <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-amber-400 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

            <div class="flex items-center justify-between border-b border-white/10 pb-3 mb-4">
                <span class="text-[10px] font-mono text-amber-400 tracking-[0.2em] uppercase flex items-center gap-2 font-bold">
                    <span class="inline-block w-2 h-2 rotate-45 bg-teal-400 animate-pulse"></span>
                    Kitab_Al_Jabr.codex
                </span>
                <div class="flex items-center gap-2 text-[9px] font-mono text-teal-400 bg-teal-950/50 px-2 py-0.5 rounded border border-teal-500/30">
                    <span class="w-1.5 h-1.5 rounded-full bg-teal-400 animate-pulse"></span>
                    WARISAN AL-KHWARIZMI
                </div>
            </div>

            <div class="grid grid-cols-2 gap-5 font-mono text-xs text-zinc-400">
                <div class="flex flex-col gap-1.5">
                    <span class="text-[9px] text-zinc-500 tracking-widest">LOGIKA_DASAR</span>
                    <span class="text-white font-bold flex items-center gap-1.5">
                        Al-Khwarizmi v4 <span class="text-amber-400 text-[10px]">[AKURAT]</span>
                    </span>
                </div>
                <div class="flex flex-col gap-1.5">
                    <span class="text-[9px] text-zinc-500 tracking-widest">STRUKTUR_SISTEM</span>
                    <span class="text-white font-bold text-glow-teal">Astro / Tailwind / Node</span>
                </div>
                <div class="flex flex-col gap-2 col-span-2 mt-1">
                    <div class="flex justify-between text-[9px] tracking-widest">
                        <span>PRESISI GEOMETRI & PERSAMAAN</span>
                        <span class="text-amber-400">100% SIMETRIS</span>
                    </div>
                    <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                        <div class="h-full bg-gradient-to-r from-teal-500 via-amber-400 to-yellow-300 w-full shadow-[0_0_10px_#f59e0b]"></div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- BAGIAN KANAN: Visual The Golden Astrolabe (3D Geometrical Ring) -->
    <div class="w-full xl:w-1/2 flex justify-center items-center mt-20 xl:mt-0 relative hero-item min-h-[300px] lg:min-h-[500px]">
        
        <!-- Cincin Geometri Luar (Astrolabe Outer Ring) -->
        <div class="absolute w-[300px] h-[300px] sm:w-[460px] sm:h-[460px] rounded-full border border-amber-500/20 animate-[spin_35s_linear_infinite_reverse] flex items-center justify-center pointer-events-none">
            <div class="absolute -top-3 bg-[#060913] border border-amber-500/50 text-amber-300 text-[9px] px-3 py-1 rounded-full font-mono shadow-[0_0_10px_rgba(245,158,11,0.3)]">AL_KHWARIZMI_LOGIC</div>
            <div class="absolute -bottom-3 bg-[#060913] border border-teal-500/50 text-teal-300 text-[9px] px-3 py-1 rounded-full font-mono shadow-[0_0_10px_rgba(20,184,166,0.3)]">SACRED_GEOMETRY</div>
            <div class="absolute -left-3 bg-[#060913] border border-yellow-500/50 text-yellow-300 text-[9px] px-3 py-1 rounded-full font-mono shadow-[0_0_10px_rgba(234,179,8,0.3)]">ASTROLABE_ENGINE</div>
        </div>

        <!-- Cincin Geometri Tengah -->
        <div class="absolute w-[220px] h-[220px] sm:w-[340px] sm:h-[340px] rounded-full border border-teal-500/30 animate-[spin_20s_linear_infinite] flex items-center justify-center">
            <span class="absolute -top-3 text-[10px] sm:text-xs font-mono text-amber-400 tracking-widest bg-[#060913] px-3 border border-amber-500/40 rounded-full">ALGORITHM HERITAGE</span>
        </div>

        <!-- Cincin Navigasi Emas -->
        <div class="absolute w-[170px] h-[170px] sm:w-[260px] sm:h-[260px] rounded-full border-2 border-t-amber-400 border-r-teal-400 border-b-transparent border-l-yellow-400 animate-[spin_12s_linear_infinite_reverse] blur-[1px]"></div>

        <!-- Inti Astrolabe Emas (The Sacred Core) -->
        <div id="astrolabe-core" class="relative w-[130px] h-[130px] sm:w-[180px] sm:h-[180px] rounded-full bg-gradient-to-br from-amber-500 via-teal-600 to-yellow-500 p-[2px] shadow-[0_0_60px_20px_rgba(245,158,11,0.25),inset_0_0_30px_rgba(255,255,255,0.5)] z-10 flex items-center justify-center overflow-hidden cursor-crosshair animate-float">
            <div class="absolute inset-0 bg-[#060913]/90 backdrop-blur-sm flex items-center justify-center">
                <!-- Glowing Core Center -->
                <div class="w-16 h-16 sm:w-24 sm:h-24 rounded-full bg-gradient-to-tr from-amber-400 to-teal-300 animate-pulse blur-md opacity-80"></div>
                <span class="font-mono text-[10px] text-amber-200 tracking-[0.2em] z-20 font-bold drop-shadow-[0_0_8px_#f59e0b]">AL-JABR</span>
            </div>
        </div>

    </div>
</section>

<script is:inline>
    (function initHeroSection() {
        document.addEventListener("DOMContentLoaded", () => {
            
            const chars = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ@#$&*+~";
            const scrambleElements = document.querySelectorAll('.scramble-text');
            
            scrambleElements.forEach(el => {
                const target = el.getAttribute('data-target');
                if (!target) return; 
                
                let iteration = 0;
                const interval = setInterval(() => {
                    el.innerText = target.split("").map((letter, index) => {
                        if(index < iteration) return target[index];
                        return chars[Math.floor(Math.random() * chars.length)];
                    }).join("");
                    if(iteration >= target.length) clearInterval(interval);
                    iteration += 1 / 3; 
                }, 30);
            });

            const heroSection = document.getElementById('hero-section');
            const astrolabeCore = document.getElementById('astrolabe-core');

            if(heroSection && astrolabeCore && typeof window.gsap !== 'undefined') {
                heroSection.addEventListener('mousemove', (e) => {
                    const rect = heroSection.getBoundingClientRect();
                    const x = (e.clientX - rect.left - rect.width/2) * 0.08;
                    const y = (e.clientY - rect.top - rect.height/2) * 0.08;
                    window.gsap.to(astrolabeCore, { x: x, y: y, rotation: (x*0.3), duration: 0.6, ease: "power2.out" });
                });
                heroSection.addEventListener('mouseleave', () => {
                    window.gsap.to(astrolabeCore, { x: 0, y: 0, rotation: 0, duration: 1.5, ease: "elastic.out(1, 0.3)" });
                });
            }
        });
    })();
</script>