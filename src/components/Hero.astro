---
---
<section id="hero-section" class="min-h-[90vh] relative z-20 pt-32 pb-16 flex flex-col justify-between">
    
    <!-- TIER 1 (ATAS): Badge & Nama -->
    <div class="w-full relative z-30">
        <div class="hero-item inline-flex items-center gap-3 px-4 py-1.5 rounded bg-[#080d1a]/80 border border-emerald-500/30 text-emerald-400 font-mono text-xs mb-6 shadow-[0_0_15px_rgba(16,185,129,0.15)]">
            <span class="w-2 h-2 rounded-full bg-cyan-400 animate-ping"></span>
            >_ LOW-LATENCY ARCHITECT // IJM.CORE
        </div>
        
        <h1 class="hero-item scramble-text text-6xl sm:text-8xl lg:text-9xl font-extrabold text-white tracking-tighter leading-[0.85] mb-4 text-glow-green drop-shadow-2xl max-w-5xl" data-target="Iqbal Marjan">
            Iqbal Marjan
        </h1>
    </div>

    <!-- TIER 2: L-Shape Layout (Diubah ke items-stretch agar tinggi kartu proporsional & stabil) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch mt-12 relative z-30">
        
        <!-- KIRI: Kartu Filosofi HFT (Diperkuat border, shadow, dan z-index agar anti-hilang) -->
        <div class="hero-item lg:col-span-5 bg-[#080d1a]/90 backdrop-blur-xl p-8 rounded-2xl border border-emerald-500/40 shadow-[0_0_30px_rgba(16,185,129,0.15)] hover:border-cyan-400/60 transition-all duration-500 group relative z-40 flex flex-col justify-center">
            <div class="flex items-center gap-4 mb-6 border-b border-white/10 pb-4">
                <img src="/foto-iqbal.jpg" alt="Iqbal Jabar" class="w-14 h-14 rounded-xl object-cover border-2 border-emerald-500/60 group-hover:scale-105 transition-transform shadow-[0_0_10px_rgba(16,185,129,0.3)]" />
                <div>
                    <h3 class="text-white font-bold text-base flex items-center gap-2">
                        Iqbal Jabar Marjan
                        <span class="w-2 h-2 bg-emerald-400 rounded-full animate-ping" title="System Online"></span>
                    </h3>
                    <p class="text-[10px] font-mono text-cyan-400 tracking-widest uppercase mt-0.5">FULLSTACK & CLOUD ENGINEER</p>
                </div>
            </div>
            
            <h2 class="text-base sm:text-lg font-light text-zinc-200 leading-relaxed font-sans">
                "<span class="font-bold text-white">Backend</span> adalah <span class="font-semibold text-emerald-400 text-glow-green">High-Frequency Pipeline</span> yang memproses data tanpa henti. <span class="font-bold text-white">Frontend</span> adalah <span class="text-cyan-400 font-semibold text-glow-cyan">Terminal Analitik</span> dengan eksekusi visual presisi nol-latensi."
            </h2>
        </div>

        <!-- TENGAH: Terminal Eksekusi Log (Telemetry HUD Anti-Bug) -->
        <div class="hero-item lg:col-span-4 bg-[#080d1a]/80 backdrop-blur-xl border border-emerald-500/30 rounded-2xl p-6 shadow-[0_0_30px_rgba(16,185,129,0.1)] relative overflow-hidden group hover:border-cyan-400/50 transition-colors duration-500 flex flex-col justify-center">
            <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-emerald-500 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

            <div class="flex items-center justify-between border-b border-white/10 pb-3 mb-4">
                <span class="text-[10px] font-mono text-emerald-400 tracking-[0.2em] uppercase flex items-center gap-2 font-bold">
                    <span class="inline-block w-2 h-2 bg-cyan-400 animate-pulse"></span>
                    Execution_Terminal.log
                </span>
                <span class="text-[9px] font-mono text-cyan-400 bg-cyan-950/60 px-2 py-0.5 rounded border border-cyan-500/30 animate-pulse">
                    LATENCY: 0.08ms
                </span>
            </div>

            <div class="space-y-3 font-mono text-xs text-zinc-400">
                <div class="flex justify-between items-center bg-black/50 p-2.5 rounded border border-white/5">
                    <span class="text-[10px] text-zinc-500">CORE_THROUGHPUT:</span>
                    <span class="text-white font-bold">Astro Engine v4 <span class="text-emerald-400 text-[10px] ml-1">[OPTIMIZED]</span></span>
                </div>
                <div class="flex justify-between items-center bg-black/50 p-2.5 rounded border border-white/5">
                    <span class="text-[10px] text-zinc-500">DATA_PIPELINE:</span>
                    <span class="text-white font-bold text-glow-cyan">Node.js / REST API / Git</span>
                </div>
                <div class="pt-1">
                    <div class="flex justify-between text-[9px] tracking-widest mb-1">
                        <span>MEMORY LEAK ZERO & STABILITY</span>
                        <span class="text-emerald-400">100% HEALTHY</span>
                    </div>
                    <div class="w-full h-1.5 bg-white/10 rounded overflow-hidden">
                        <div class="h-full bg-gradient-to-r from-emerald-500 via-cyan-400 to-blue-500 w-full shadow-[0_0_10px_#10b981]"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- KANAN: Global Cloud Node -->
        <div class="hero-item lg:col-span-3 flex justify-center items-center relative py-8 lg:py-0 lg:absolute lg:right-4 lg:top-1/4 pointer-events-auto">
            
            <!-- Cincin Server Racks -->
            <div class="absolute w-[260px] h-[260px] sm:w-[350px] sm:h-[350px] rounded-full border border-emerald-500/20 animate-[spin_25s_linear_infinite_reverse] flex items-center justify-center pointer-events-none">
                <div class="absolute -top-3 bg-[#030508] border border-emerald-500/50 text-emerald-400 text-[9px] px-3 py-1 rounded font-mono shadow-[0_0_10px_rgba(16,185,129,0.3)]">CLOUD_CLUSTER_01</div>
                <div class="absolute -bottom-3 bg-[#030508] border border-cyan-400/50 text-cyan-300 text-[9px] px-3 py-1 rounded font-mono shadow-[0_0_10px_rgba(6,182,212,0.3)]">ZERO_LATENCY_UI</div>
            </div>

            <!-- Cincin Fiber Optic -->
            <div class="absolute w-[180px] h-[180px] sm:w-[240px] sm:h-[240px] rounded-full border border-cyan-400/30 animate-[spin_15s_linear_infinite] flex items-center justify-center">
                <span class="absolute -top-3 text-[9px] font-mono text-blue-400 tracking-widest bg-[#030508] px-3 border border-blue-500/40 rounded">GLOBAL DATA MESH</span>
            </div>

            <!-- Cincin Throughput -->
            <div class="absolute w-[140px] h-[140px] sm:w-[180px] sm:h-[180px] rounded-full border-2 border-t-emerald-500 border-r-cyan-400 border-b-transparent border-l-blue-500 animate-[spin_8s_linear_infinite_reverse] blur-[1px]"></div>

            <!-- Inti Cloud Node -->
            <div id="cloud-node" class="relative w-[110px] h-[110px] sm:w-[140px] sm:h-[140px] rounded bg-gradient-to-br from-emerald-500 via-cyan-600 to-blue-500 p-[2px] shadow-[0_0_50px_15px_rgba(16,185,129,0.35),inset_0_0_20px_rgba(255,255,255,0.5)] z-10 flex items-center justify-center overflow-hidden cursor-crosshair animate-float rotate-45">
                <div class="absolute inset-0 bg-[#030508]/90 backdrop-blur-sm flex items-center justify-center -rotate-45">
                    <div class="w-14 h-14 sm:w-20 sm:h-20 rounded bg-gradient-to-tr from-emerald-500 to-cyan-400 animate-pulse blur-md opacity-80"></div>
                    <span class="font-mono text-[10px] text-emerald-200 tracking-[0.3em] z-20 font-bold drop-shadow-[0_0_8px_#10b981]">NODE_01</span>
                </div>
            </div>

        </div>

    </div>
</section>

<script is:inline>
    (function initHeroSection() {
        document.addEventListener("DOMContentLoaded", () => {
            
            // 1. SCRAMBLE TEXT EFFECT
            const chars = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ@#$&*+~";
            const scrambleElements = document.querySelectorAll('.scramble-text');
            scrambleElements.forEach(el => {
                const target = el.getAttribute('data-target');
                if (!target) return; 
                let iteration = 0;
                const interval = setInterval(() => {
                    el.innerText = target.split("").map((letter, index) => {
                        if(index < iteration) return target[index];
                        return chars[Math.floor(Math.random() * chars.length)];
                    }).join("");
                    if(iteration >= target.length) clearInterval(interval);
                    iteration += 1 / 3; 
                }, 30);
            });

            // 2. CLOUD NODE HOVER EFFECT
            const heroSection = document.getElementById('hero-section');
            const cloudNode = document.getElementById('cloud-node');
            if(heroSection && cloudNode && typeof window.gsap !== 'undefined') {
                heroSection.addEventListener('mousemove', (e) => {
                    const rect = heroSection.getBoundingClientRect();
                    const x = (e.clientX - rect.left - rect.width/2) * 0.08;
                    const y = (e.clientY - rect.top - rect.height/2) * 0.08;
                    window.gsap.to(cloudNode, { x: x, y: y, rotation: 45 + (x*0.4), duration: 0.6, ease: "power2.out" });
                });
                heroSection.addEventListener('mouseleave', () => {
                    window.gsap.to(cloudNode, { x: 0, y: 0, rotation: 45, duration: 1.5, ease: "elastic.out(1, 0.3)" });
                });
            }

            // 3. FAIL-SAFE (PENGAMAN ANTI-HILANG):
            // Memaksa semua kartu (.hero-item) wajib muncul (opacity 1) jika dalam 1.5 detik GSAP gagal memunculkannya.
            setTimeout(() => {
                document.querySelectorAll('.hero-item').forEach(el => {
                    if (window.getComputedStyle(el).opacity === '0') {
                        el.style.transition = 'opacity 0.8s ease-out, transform 0.8s ease-out';
                        el.style.opacity = '1';
                        el.style.transform = 'translateY(0)';
                    }
                });
            }, 1500);

        });
    })();
</script>