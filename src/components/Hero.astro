---
---
<section id="hero-section" class="min-h-[90vh] relative z-20 pt-32 pb-16 flex flex-col justify-between">
    
    <!-- TIER 1 (ATAS): Badge & Nama -->
    <div class="w-full relative z-30">
        <div class="hero-item inline-flex items-center gap-3 px-4 py-1.5 rounded-full bg-[#0d0d12]/80 border border-orange-500/30 text-orange-400 font-mono text-xs mb-6 shadow-[0_0_15px_rgba(249,115,22,0.15)]">
            <span class="w-2 h-2 rounded-full bg-cyan-400 animate-ping"></span>
            >_ FUINJUTSU ARCHITECT // IJM.CORE
        </div>
        
        <h1 class="hero-item scramble-text text-6xl sm:text-8xl lg:text-9xl font-extrabold text-white tracking-tighter leading-[0.85] mb-4 text-glow-orange drop-shadow-2xl max-w-5xl" data-target="Iqbal Marjan">
            Iqbal Marjan
        </h1>
    </div>

    <!-- TIER 2: L-Shape Layout (Teks & Gulungan Segel di Bawah, Bola Chakra di Kanan) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-end mt-12 relative z-30">
        
        <!-- KIRI: Kartu Filosofi Shinobi -->
        <div class="hero-item lg:col-span-5 bg-[#0d0d12]/70 backdrop-blur-md p-8 rounded-3xl border border-orange-500/20 shadow-xl hover:border-cyan-400/40 transition-all duration-500 group">
            <div class="flex items-center gap-3 mb-6 border-b border-white/10 pb-4">
                <img src="/foto-iqbal.jpg" alt="Iqbal Jabar" class="w-12 h-12 rounded-full object-cover border-2 border-orange-500/50 group-hover:scale-105 transition-transform" />
                <div>
                    <h3 class="text-white font-bold text-sm">Iqbal Jabar Marjan</h3>
                    <p class="text-[10px] font-mono text-cyan-400 tracking-widest">CYBER SHINOBI ARCHITECT</p>
                </div>
            </div>
            
            <h2 class="text-base sm:text-lg font-light text-zinc-300 leading-relaxed font-sans">
                "<span class="font-bold text-white">Backend</span> adalah <span class="font-semibold text-orange-500 text-glow-orange">Fuinjutsu (Jurus Segel)</span> yang mengunci data dengan aman. <span class="font-bold text-white">Frontend</span> adalah <span class="text-cyan-400 font-semibold text-glow-cyan">Ninjutsu & Genjutsu</span> yang menyajikan ilusi visual presisi tanpa *lag*."
            </h2>
        </div>

        <!-- TENGAH: Gulungan Segel Codex (Telemetry HUD Anti-Bug) -->
        <div class="hero-item lg:col-span-4 bg-[#0d0d12]/80 backdrop-blur-xl border border-orange-500/30 rounded-3xl p-6 shadow-[0_0_30px_rgba(249,115,22,0.1)] relative overflow-hidden group hover:border-cyan-400/50 transition-colors duration-500">
            <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-orange-500 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

            <div class="flex items-center justify-between border-b border-white/10 pb-3 mb-4">
                <span class="text-[10px] font-mono text-orange-400 tracking-[0.2em] uppercase flex items-center gap-2 font-bold">
                    <span class="inline-block w-2 h-2 rotate-45 bg-cyan-400 animate-pulse"></span>
                    Gulungan_Segel.codex
                </span>
                <span class="text-[9px] font-mono text-cyan-400 bg-cyan-950/60 px-2 py-0.5 rounded border border-cyan-500/30 animate-pulse">
                    ALIANSI LANGIT
                </span>
            </div>

            <div class="space-y-3 font-mono text-xs text-zinc-400">
                <div class="flex justify-between items-center bg-black/40 p-2.5 rounded-xl border border-white/5">
                    <span class="text-[10px] text-zinc-500">CHAKRA_CORE:</span>
                    <span class="text-white font-bold">Astro Engine v4 <span class="text-orange-400 text-[10px] ml-1">[STABIL]</span></span>
                </div>
                <div class="flex justify-between items-center bg-black/40 p-2.5 rounded-xl border border-white/5">
                    <span class="text-[10px] text-zinc-500">FORMULA_SEGEL:</span>
                    <span class="text-white font-bold text-glow-cyan">Tailwind / Node.js</span>
                </div>
                <div class="pt-1">
                    <div class="flex justify-between text-[9px] tracking-widest mb-1">
                        <span>PRESISI KENDALI CHAKRA</span>
                        <span class="text-orange-400">100% PRECISI</span>
                    </div>
                    <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                        <div class="h-full bg-gradient-to-r from-orange-500 via-red-500 to-cyan-400 w-full shadow-[0_0_10px_#f97316]"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- KANAN: Bola Chakra Fuinjutsu (Melayang di Kanan) -->
        <div class="hero-item lg:col-span-3 flex justify-center items-center relative py-8 lg:py-0 lg:absolute lg:right-4 lg:top-1/4 pointer-events-auto">
            
            <!-- Cincin Segel Luar -->
            <div class="absolute w-[260px] h-[260px] sm:w-[350px] sm:h-[350px] rounded-full border border-orange-500/20 animate-[spin_30s_linear_infinite_reverse] flex items-center justify-center pointer-events-none">
                <div class="absolute -top-3 bg-[#08080c] border border-orange-500/50 text-orange-400 text-[9px] px-3 py-1 rounded-full font-mono shadow-[0_0_10px_rgba(249,115,22,0.3)]">FUINJUTSU_LOGIC</div>
                <div class="absolute -bottom-3 bg-[#08080c] border border-cyan-400/50 text-cyan-300 text-[9px] px-3 py-1 rounded-full font-mono shadow-[0_0_10px_rgba(34,211,238,0.3)]">GENJUTSU_UI</div>
            </div>

            <!-- Cincin Segel Tengah -->
            <div class="absolute w-[180px] h-[180px] sm:w-[240px] sm:h-[240px] rounded-full border border-cyan-400/30 animate-[spin_18s_linear_infinite] flex items-center justify-center">
                <span class="absolute -top-3 text-[9px] font-mono text-red-400 tracking-widest bg-[#08080c] px-3 border border-red-500/40 rounded-full">CHAKRA ENGINE</span>
            </div>

            <!-- Cincin Energi Api Chakra -->
            <div class="absolute w-[140px] h-[140px] sm:w-[180px] sm:h-[180px] rounded-full border-2 border-t-orange-500 border-r-cyan-400 border-b-transparent border-l-red-500 animate-[spin_10s_linear_infinite_reverse] blur-[1px]"></div>

            <!-- Inti Chakra Sphere -->
            <div id="chakra-core" class="relative w-[110px] h-[110px] sm:w-[140px] sm:h-[140px] rounded-full bg-gradient-to-br from-orange-500 via-red-600 to-cyan-400 p-[2px] shadow-[0_0_50px_15px_rgba(249,115,22,0.35),inset_0_0_20px_rgba(255,255,255,0.5)] z-10 flex items-center justify-center overflow-hidden cursor-crosshair animate-float">
                <div class="absolute inset-0 bg-[#08080c]/90 backdrop-blur-sm flex items-center justify-center">
                    <div class="w-14 h-14 sm:w-20 sm:h-20 rounded-full bg-gradient-to-tr from-orange-500 to-cyan-400 animate-pulse blur-md opacity-80"></div>
                    <span class="font-mono text-[10px] text-orange-200 tracking-[0.3em] z-20 font-bold drop-shadow-[0_0_8px_#f97316]">SEGEL</span>
                </div>
            </div>

        </div>

    </div>
</section>

<script is:inline>
    (function initHeroSection() {
        document.addEventListener("DOMContentLoaded", () => {
            const chars = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ@#$&*+~";
            const scrambleElements = document.querySelectorAll('.scramble-text');
            scrambleElements.forEach(el => {
                const target = el.getAttribute('data-target');
                if (!target) return; 
                let iteration = 0;
                const interval = setInterval(() => {
                    el.innerText = target.split("").map((letter, index) => {
                        if(index < iteration) return target[index];
                        return chars[Math.floor(Math.random() * chars.length)];
                    }).join("");
                    if(iteration >= target.length) clearInterval(interval);
                    iteration += 1 / 3; 
                }, 30);
            });

            const heroSection = document.getElementById('hero-section');
            const chakraCore = document.getElementById('chakra-core');
            if(heroSection && chakraCore && typeof window.gsap !== 'undefined') {
                heroSection.addEventListener('mousemove', (e) => {
                    const rect = heroSection.getBoundingClientRect();
                    const x = (e.clientX - rect.left - rect.width/2) * 0.08;
                    const y = (e.clientY - rect.top - rect.height/2) * 0.08;
                    window.gsap.to(chakraCore, { x: x, y: y, rotation: (x*0.4), duration: 0.6, ease: "power2.out" });
                });
                heroSection.addEventListener('mouseleave', () => {
                    window.gsap.to(chakraCore, { x: 0, y: 0, rotation: 0, duration: 1.5, ease: "elastic.out(1, 0.3)" });
                });
            }
        });
    })();
</script>