---
---
<section id="hero-section" class="min-h-[90vh] relative z-20 pt-32 pb-16 flex flex-col justify-between">
    
    <!-- TIER 1 (ATAS): Badge & Nama Megah (Cinematic Typography) -->
    <div class="w-full relative z-30">
        <div class="hero-item inline-flex items-center gap-3 px-4 py-1.5 rounded-full bg-[#0a1118]/80 border border-emerald-500/30 text-emerald-400 font-mono text-xs mb-6 shadow-[0_0_15px_rgba(16,185,129,0.1)]">
            <span class="w-2 h-2 rounded-full bg-cyan-400 animate-ping"></span>
            >_ ARSITEK ISTANA LANGIT // IJM.CORE
        </div>
        
        <h1 class="hero-item scramble-text text-6xl sm:text-8xl lg:text-9xl font-extrabold text-white tracking-tighter leading-[0.85] mb-4 text-glow-cyan drop-shadow-2xl max-w-5xl" data-target="Iqbal Marjan">
            Iqbal Marjan
        </h1>
    </div>

    <!-- TIER 2 (TENGAH & BAWAH): L-Shape Layout (Teks & Prasasti di Bawah, Kristal di Kanan) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-end mt-12 relative z-30">
        
        <!-- KIRI: Kartu Filosofi Laputa (Spans 5 Kolom) -->
        <div class="hero-item lg:col-span-5 bg-[#0a1118]/70 backdrop-blur-md p-8 rounded-3xl border border-emerald-500/20 shadow-xl hover:border-cyan-400/40 transition-all duration-500 group">
            <div class="flex items-center gap-3 mb-6 border-b border-white/10 pb-4">
                <img src="/foto-iqbal.jpg" alt="Iqbal Jabar" class="w-12 h-12 rounded-full object-cover border-2 border-emerald-500/40 group-hover:scale-105 transition-transform" />
                <div>
                    <h3 class="text-white font-bold text-sm">Iqbal Jabar Marjan</h3>
                    <p class="text-[10px] font-mono text-cyan-400 tracking-widest">LEAD FRONTEND & BACKEND</p>
                </div>
            </div>
            
            <h2 class="text-base sm:text-lg font-light text-zinc-300 leading-relaxed font-serif italic">
                "<span class="font-bold text-white not-italic">Backend</span> adalah <span class="font-semibold text-cyan-400 not-italic text-glow-cyan">Batu Levitas</span> yang menopang sistem. <span class="font-bold text-white not-italic">Frontend</span> adalah <span class="text-emerald-400 font-semibold not-italic text-glow-emerald">Ekosistem Alam</span> yang bersemi di atasnya."
            </h2>
        </div>

        <!-- TENGAH: Prasasti Penjaga Log (Spans 4 Kolom) -->
        <div class="hero-item lg:col-span-4 bg-[#0a1118]/80 backdrop-blur-xl border border-emerald-500/30 rounded-3xl p-6 shadow-[0_0_30px_rgba(16,185,129,0.08)] relative overflow-hidden group hover:border-cyan-500/50 transition-colors duration-500">
            <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-cyan-400 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

            <div class="flex items-center justify-between border-b border-white/10 pb-3 mb-4">
                <span class="text-[10px] font-mono text-cyan-400 tracking-[0.2em] uppercase flex items-center gap-2 font-bold">
                    <span class="inline-block w-2 h-2 rotate-45 bg-amber-400 animate-pulse"></span>
                    Prasasti_Penjaga.log
                </span>
                <span class="text-[9px] font-mono text-emerald-400 bg-emerald-950/60 px-2 py-0.5 rounded border border-emerald-500/30 animate-pulse">
                    700 TAHUN AKTIF
                </span>
            </div>

            <div class="space-y-3 font-mono text-xs text-zinc-400">
                <div class="flex justify-between items-center bg-black/40 p-2.5 rounded-xl border border-white/5">
                    <span class="text-[10px] text-zinc-500">INTI_LEVITAS:</span>
                    <span class="text-white font-bold">Aether Core v4 <span class="text-cyan-400 text-[10px] ml-1">[STABIL]</span></span>
                </div>
                <div class="flex justify-between items-center bg-black/40 p-2.5 rounded-xl border border-white/5">
                    <span class="text-[10px] text-zinc-500">TECH_STACK:</span>
                    <span class="text-white font-bold text-glow-amber">Astro / Tailwind / Node</span>
                </div>
                <div class="pt-1">
                    <div class="flex justify-between text-[9px] tracking-widest mb-1">
                        <span>SINKRONISASI ALAM & LOGIKA</span>
                        <span class="text-emerald-400">100% HARMONI</span>
                    </div>
                    <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
                        <div class="h-full bg-gradient-to-r from-emerald-500 via-cyan-400 to-amber-400 w-full shadow-[0_0_10px_#06b6d4]"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- KANAN: Kristal Levitas (Spans 3 Kolom - Posisi Melayang di Pojok Kanan Atas/Tengah) -->
        <div class="hero-item lg:col-span-3 flex justify-center items-center relative py-8 lg:py-0 lg:absolute lg:right-4 lg:top-1/4 pointer-events-auto">
            
            <!-- Cincin Prasasti Luar -->
            <div class="absolute w-[260px] h-[260px] sm:w-[350px] sm:h-[350px] rounded-full border border-emerald-500/20 animate-[spin_35s_linear_infinite_reverse] flex items-center justify-center pointer-events-none">
                <div class="absolute -top-3 bg-[#070b12] border border-cyan-500/50 text-cyan-300 text-[9px] px-3 py-1 rounded-full font-mono shadow-[0_0_10px_rgba(6,182,212,0.3)]">VOLUSPA_LOGIC</div>
                <div class="absolute -bottom-3 bg-[#070b12] border border-emerald-500/50 text-emerald-300 text-[9px] px-3 py-1 rounded-full font-mono shadow-[0_0_10px_rgba(16,185,129,0.3)]">NATURE_UI</div>
            </div>

            <!-- Cincin Ukiran Tengah -->
            <div class="absolute w-[180px] h-[180px] sm:w-[240px] sm:h-[240px] rounded-full border border-cyan-500/30 animate-[spin_20s_linear_infinite] flex items-center justify-center">
                <span class="absolute -top-3 text-[9px] font-mono text-emerald-400 tracking-widest bg-[#070b12] px-3 border border-emerald-500/40 rounded-full">TENKU NO SHIRO</span>
            </div>

            <!-- Cincin Energi Emas -->
            <div class="absolute w-[140px] h-[140px] sm:w-[180px] sm:h-[180px] rounded-full border-2 border-t-cyan-400 border-r-emerald-400 border-b-transparent border-l-amber-400 animate-[spin_12s_linear_infinite_reverse] blur-[1px]"></div>

            <!-- Inti Kristal Levitas -->
            <div id="crystal-core" class="relative w-[110px] h-[110px] sm:w-[140px] sm:h-[140px] rounded-2xl rotate-45 bg-gradient-to-br from-cyan-500 via-emerald-600 to-amber-500 p-[2px] shadow-[0_0_50px_15px_rgba(6,182,212,0.3),inset_0_0_20px_rgba(255,255,255,0.5)] z-10 flex items-center justify-center overflow-hidden cursor-crosshair animate-float">
                <div class="absolute inset-0 bg-[#070b12]/90 backdrop-blur-sm flex items-center justify-center">
                    <div class="w-14 h-14 sm:w-20 sm:h-20 rounded-full bg-gradient-to-tr from-cyan-400 to-emerald-300 animate-pulse blur-md opacity-80"></div>
                    <span class="font-mono text-[10px] text-cyan-200 tracking-[0.3em] z-20 -rotate-45 font-bold drop-shadow-[0_0_8px_#06b6d4]">LAPUTA</span>
                </div>
            </div>

        </div>

    </div>
</section>

<script is:inline>
    (function initHeroSection() {
        document.addEventListener("DOMContentLoaded", () => {
            const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&*+~";
            const scrambleElements = document.querySelectorAll('.scramble-text');
            scrambleElements.forEach(el => {
                const target = el.getAttribute('data-target');
                if (!target) return; 
                let iteration = 0;
                const interval = setInterval(() => {
                    el.innerText = target.split("").map((letter, index) => {
                        if(index < iteration) return target[index];
                        return chars[Math.floor(Math.random() * chars.length)];
                    }).join("");
                    if(iteration >= target.length) clearInterval(interval);
                    iteration += 1 / 3; 
                }, 30);
            });

            const heroSection = document.getElementById('hero-section');
            const crystalCore = document.getElementById('crystal-core');
            if(heroSection && crystalCore && typeof window.gsap !== 'undefined') {
                heroSection.addEventListener('mousemove', (e) => {
                    const rect = heroSection.getBoundingClientRect();
                    const x = (e.clientX - rect.left - rect.width/2) * 0.08;
                    const y = (e.clientY - rect.top - rect.height/2) * 0.08;
                    window.gsap.to(crystalCore, { x: x, y: y, rotation: 45 + (x*0.2), duration: 0.6, ease: "power2.out" });
                });
                heroSection.addEventListener('mouseleave', () => {
                    window.gsap.to(crystalCore, { x: 0, y: 0, rotation: 45, duration: 1.5, ease: "elastic.out(1, 0.3)" });
                });
            }
        });
    })();
</script>