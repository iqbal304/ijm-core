---
---
<div id="music-player" class="fixed bottom-6 right-6 z-50 flex items-center gap-4 bg-[#030508]/90 border border-emerald-500/30 backdrop-blur-2xl p-2 rounded shadow-[0_0_25px_rgba(16,185,129,0.15)] group hover:border-cyan-400/50 transition-all duration-500">
    
    <div class="w-10 h-10 rounded border border-emerald-500/30 overflow-hidden flex items-center justify-center bg-[#080d1a] relative shadow-[inset_0_0_10px_rgba(6,182,212,0.2)]">
        <div class="absolute inset-0 bg-cyan-400/20 animate-pulse"></div>
        <div class="w-3.5 h-3.5 bg-gradient-to-tr from-emerald-500 to-cyan-400 rounded-sm rotate-45 z-10 absolute border border-white/40 shadow-[0_0_8px_#10b981]"></div>
        <div id="record-spin" class="w-full h-full border-2 border-dashed border-emerald-500/60 rounded animate-spin-slow" style="animation-play-state: paused;"></div>
    </div>
    
    <div class="flex flex-col pr-2">
        <span class="text-[8px] font-mono text-emerald-400 uppercase tracking-[0.2em] flex items-center gap-1">
            <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-ping"></span>
            Server_Hum_Audio
        </span>
        <span class="text-[10px] text-zinc-200 font-mono tracking-widest font-semibold drop-shadow-[0_0_5px_rgba(16,185,129,0.5)]">SERVER.MP3</span>
    </div>

    <button id="play-btn" class="w-9 h-9 flex items-center justify-center rounded bg-emerald-500/10 hover:bg-cyan-400/20 text-cyan-400 hover:text-white transition-all duration-300 border border-emerald-500/20 hover:border-cyan-400/50 mr-1 cursor-pointer">
        <svg id="icon-play" class="w-4 h-4 ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        <svg id="icon-pause" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
    </button>
</div>

<style>
    .playing-glow {
        box-shadow: 0 0 20px rgba(16, 185, 129, 0.4), inset 0 0 10px rgba(6, 182, 212, 0.2);
        border-color: rgba(16, 185, 129, 0.6) !important;
    }
</style>

<script is:inline>
    if (typeof Howl !== 'undefined') {
        const ambientMusic = new Howl({ src: ['/server_ambient.mp3'], loop: true, volume: 0.4 });
        const player = document.getElementById('music-player');
        const playBtn = document.getElementById('play-btn');
        const iconPlay = document.getElementById('icon-play');
        const iconPause = document.getElementById('icon-pause');
        const recordSpin = document.getElementById('record-spin');

        playBtn.addEventListener('click', () => {
            if (ambientMusic.playing()) {
                ambientMusic.pause();
                recordSpin.style.animationPlayState = 'paused';
                player.classList.remove('playing-glow');
                iconPlay.classList.remove('hidden');
                iconPause.classList.add('hidden');
            } else {
                ambientMusic.play();
                recordSpin.style.animationPlayState = 'running';
                player.classList.add('playing-glow');
                iconPlay.classList.add('hidden');
                iconPause.classList.remove('hidden');
            }
        });
    }
</script>