---
---
<div id="music-player" class="fixed bottom-6 right-6 z-50 flex items-center gap-4 bg-[#060913]/85 border border-amber-500/20 backdrop-blur-2xl p-2 rounded-full shadow-[0_0_25px_rgba(245,158,11,0.15)] group hover:border-teal-400/50 transition-all duration-500">
    
    <div class="w-10 h-10 rounded-full border border-amber-500/30 overflow-hidden flex items-center justify-center bg-[#080d1a] relative shadow-[inset_0_0_10px_rgba(20,184,166,0.2)]">
        <div class="absolute inset-0 bg-teal-500/20 animate-pulse"></div>
        <div class="w-3.5 h-3.5 bg-gradient-to-tr from-amber-400 to-teal-300 rounded-sm rotate-45 z-10 absolute border border-white/40 shadow-[0_0_8px_#f59e0b]"></div>
        <div id="record-spin" class="w-full h-full border-2 border-dashed border-amber-400/60 rounded-full animate-spin-slow" style="animation-play-state: paused;"></div>
    </div>
    
    <div class="flex flex-col pr-2">
        <span class="text-[8px] font-mono text-amber-400 uppercase tracking-[0.2em] flex items-center gap-1">
            <span class="w-1.5 h-1.5 rounded-full bg-teal-400 animate-ping"></span>
            Instrumen_Gambus
        </span>
        <span class="text-[10px] text-zinc-200 font-mono tracking-widest font-semibold drop-shadow-[0_0_5px_rgba(245,158,11,0.5)]">OUD_AMBIENT.MP3</span>
    </div>

    <button id="play-btn" class="w-9 h-9 flex items-center justify-center rounded-full bg-amber-500/10 hover:bg-teal-500/20 text-teal-400 hover:text-white transition-all duration-300 border border-amber-500/20 hover:border-teal-400/50 mr-1 cursor-pointer">
        <svg id="icon-play" class="w-4 h-4 ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        <svg id="icon-pause" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
    </button>
</div>

<style>
    .playing-glow {
        box-shadow: 0 0 20px rgba(245, 158, 11, 0.4), inset 0 0 10px rgba(20, 184, 166, 0.2);
        border-color: rgba(245, 158, 11, 0.6) !important;
    }
</style>

<script is:inline>
    if (typeof Howl !== 'undefined') {
        const ambientMusic = new Howl({ src: ['/oud_ambient.mp3'], loop: true, volume: 0.4 });
        const player = document.getElementById('music-player');
        const playBtn = document.getElementById('play-btn');
        const iconPlay = document.getElementById('icon-play');
        const iconPause = document.getElementById('icon-pause');
        const recordSpin = document.getElementById('record-spin');

        playBtn.addEventListener('click', () => {
            if (ambientMusic.playing()) {
                ambientMusic.pause();
                recordSpin.style.animationPlayState = 'paused';
                player.classList.remove('playing-glow');
                iconPlay.classList.remove('hidden');
                iconPause.classList.add('hidden');
            } else {
                ambientMusic.play();
                recordSpin.style.animationPlayState = 'running';
                player.classList.add('playing-glow');
                iconPlay.classList.add('hidden');
                iconPause.classList.remove('hidden');
            }
        });
    }
</script>