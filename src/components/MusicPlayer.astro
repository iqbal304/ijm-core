---
---
<div id="music-player" class="fixed bottom-6 right-6 z-50 flex items-center gap-4 bg-[#02000a]/70 border border-white/10 backdrop-blur-2xl p-2 rounded-full shadow-[0_0_20px_rgba(14,165,233,0.15)] group hover:border-sky-500/50 transition-all duration-500">
    
    <div class="w-9 h-9 rounded-full border border-zinc-700 overflow-hidden flex items-center justify-center bg-zinc-950 relative">
        <div class="absolute inset-0 bg-sky-500/20 animate-pulse"></div>
        <div class="w-3 h-3 bg-[#02000a] rounded-full z-10 absolute border border-zinc-700"></div>
        <div id="record-spin" class="w-full h-full bg-linear-to-tr from-violet-600/40 to-sky-500/40 rounded-full animate-spin-slow shadow-[inset_0_0_10px_#0ea5e9]" style="animation-play-state: paused;"></div>
    </div>
    
    <div class="flex flex-col pr-2">
        <span class="text-[8px] font-mono text-sky-400 uppercase tracking-[0.2em]">Sinyal_Aktif</span>
        <span class="text-[10px] text-white font-mono tracking-widest animate-pulse">AMBIENT.MP3</span>
    </div>

    <button id="play-btn" class="w-9 h-9 flex items-center justify-center rounded-full bg-white/5 hover:bg-sky-500/20 text-sky-400 hover:text-white transition-all duration-300 border border-white/5 hover:border-sky-500/50 mr-1">
        <svg id="icon-play" class="w-4 h-4 ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        <svg id="icon-pause" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
    </button>
</div>

<style>
    /* Menambahkan sedikit glow pada kontainer saat aktif */
    .playing-glow {
        box-shadow: 0 0 15px rgba(14, 165, 233, 0.4);
    }
</style>

<script is:inline>
    if (typeof Howl !== 'undefined') {
        const ambientMusic = new Howl({ 
            src: ['/Ambient.mp3'], 
            loop: true, 
            volume: 0.5 
        });

        const player = document.getElementById('music-player');
        const playBtn = document.getElementById('play-btn');
        const iconPlay = document.getElementById('icon-play');
        const iconPause = document.getElementById('icon-pause');
        const recordSpin = document.getElementById('record-spin');

        playBtn.addEventListener('click', () => {
            if (ambientMusic.playing()) {
                ambientMusic.pause();
                recordSpin.style.animationPlayState = 'paused';
                player.classList.remove('playing-glow');
                iconPlay.classList.remove('hidden');
                iconPause.classList.add('hidden');
            } else {
                ambientMusic.play();
                recordSpin.style.animationPlayState = 'running';
                player.classList.add('playing-glow');
                iconPlay.classList.add('hidden');
                iconPause.classList.remove('hidden');
            }
        });
    }
</script>