---
import '../styles/global.css';
interface Props { title: string; }
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Inter:wght@300;400;500;700&family=Cinzel:wght@600;700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" is:inline></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/howler/2.2.4/howler.min.js" is:inline></script>
    
    <style>
        @media (pointer: coarse) {
            #cursor-dot, #cursor-ring { display: none !important; }
            body { cursor: auto !important; }
        }
    </style>
</head>
<body class="antialiased selection:bg-cyan-500/30 relative overflow-x-hidden">
    
    <!-- ENGINE PARTIKEL AETHER (Laputa Floating Magic) -->
    <canvas id="aether-canvas" class="fixed inset-0 w-full h-full pointer-events-none -z-30 opacity-70"></canvas>
    
    <!-- Laputa Ambient Glow (Cyan & Moss Green) -->
    <div class="fixed top-[-10%] left-[-10%] w-[50vw] h-[50vw] bg-cyan-900/15 blur-[150px] rounded-full pointer-events-none -z-20 mix-blend-screen"></div>
    <div class="fixed bottom-[-10%] right-[-10%] w-[40vw] h-[40vw] bg-emerald-900/15 blur-[130px] rounded-full pointer-events-none -z-20 mix-blend-screen"></div>

    <!-- KURSOR KRISTAL LEVITAS -->
    <div id="cursor-dot" class="fixed top-0 left-0 w-2 h-2 bg-cyan-300 rounded-full pointer-events-none z-[9999] shadow-[0_0_12px_#06b6d4]"></div>
    
    <div id="cursor-ring" class="fixed top-0 left-0 w-8 h-8 border border-emerald-500/50 rounded-full pointer-events-none z-[9998] flex items-center justify-center mix-blend-screen">
        <div class="absolute w-1.5 h-1.5 bg-amber-400/60 rounded-full animate-ping"></div>
    </div>

    <slot />
    
    <script is:inline>
        // SCRIPT KANVAS: PARTIKEL AETHER MELAYANG KE ATAS
        const canvas = document.getElementById('aether-canvas');
        const ctx = canvas.getContext('2d');
        let width, height, motes = [];

        function initMotes() {
            width = canvas.width = window.innerWidth;
            height = canvas.height = window.innerHeight;
            motes = [];
            for (let i = 0; i < 80; i++) {
                motes.push({
                    x: Math.random() * width,
                    y: Math.random() * height,
                    size: Math.random() * 2.5 + 0.5,
                    speedY: Math.random() * 0.6 + 0.2,
                    speedX: (Math.random() - 0.5) * 0.3,
                    opacity: Math.random() * 0.7 + 0.2,
                    color: Math.random() > 0.3 ? '#06b6d4' : (Math.random() > 0.5 ? '#10b981' : '#f59e0b')
                });
            }
        }

        function animateMotes() {
            ctx.clearRect(0, 0, width, height);
            for (let m of motes) {
                m.y -= m.speedY;
                m.x += m.speedX;
                if (m.y < 0) { m.y = height; m.x = Math.random() * width; }
                if (m.x < 0) m.x = width;
                if (m.x > width) m.x = 0;

                ctx.beginPath();
                ctx.fillStyle = m.color;
                ctx.globalAlpha = m.opacity;
                ctx.shadowBlur = 8;
                ctx.shadowColor = m.color;
                ctx.arc(m.x, m.y, m.size, 0, Math.PI * 2);
                ctx.fill();
            }
            requestAnimationFrame(animateMotes);
        }

        window.addEventListener('resize', initMotes);
        initMotes();
        animateMotes();
        
        if (typeof gsap !== 'undefined') {
            gsap.registerPlugin(ScrollTrigger);

            const dot = document.getElementById('cursor-dot');
            const ring = document.getElementById('cursor-ring');

            window.addEventListener('mousemove', (e) => {
                gsap.to(dot, { x: e.clientX - 4, y: e.clientY - 4, duration: 0 });
                gsap.to(ring, { x: e.clientX - 16, y: e.clientY - 16, duration: 0.2, ease: "power2.out" });
            });

            const hoverSound = new Howl({ src: ['/hover.mp3'], volume: 0.15 });

            const addHoverEffect = () => {
                const clickables = document.querySelectorAll('a, button, #crystal-core, .group');
                clickables.forEach(el => {
                    el.addEventListener('mouseenter', () => {
                        if(hoverSound.state() === 'loaded') hoverSound.play(); 
                        gsap.to(ring, { scale: 1.6, borderColor: '#06b6d4', backgroundColor: 'rgba(6, 182, 212, 0.1)', duration: 0.3 });
                        gsap.to(dot, { scale: 1.5, backgroundColor: '#f59e0b', duration: 0.3 });
                    });
                    el.addEventListener('mouseleave', () => {
                        gsap.to(ring, { scale: 1, borderColor: 'rgba(16, 185, 129, 0.5)', backgroundColor: 'transparent', duration: 0.3 });
                        gsap.to(dot, { scale: 1, backgroundColor: '#67e8f9', duration: 0.3 });
                    });
                });
            };
            setTimeout(addHoverEffect, 1000); 
        }
    </script>
</body>
</html>