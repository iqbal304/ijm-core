---
import '../styles/global.css';
interface Props { title: string; }
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Inter:wght@300;400;500;700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" is:inline></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/howler/2.2.4/howler.min.js" is:inline></script>
    
    <style>
        @media (pointer: coarse) {
            #cursor-dot, #cursor-ring { display: none !important; }
            body { cursor: auto !important; }
        }
    </style>
</head>
<body class="antialiased selection:bg-orange-500/30 relative overflow-x-hidden">
    
    <!-- ENGINE PARTIKEL CHAKRA EMBERS -->
    <canvas id="chakra-canvas" class="fixed inset-0 w-full h-full pointer-events-none -z-30 opacity-70"></canvas>
    
    <!-- Ambient Glow (Chakra Crimson & Electric Cyan) -->
    <div class="fixed top-[-10%] left-[-10%] w-[50vw] h-[50vw] bg-orange-600/15 blur-[150px] rounded-full pointer-events-none -z-20 mix-blend-screen"></div>
    <div class="fixed bottom-[-10%] right-[-10%] w-[40vw] h-[40vw] bg-cyan-600/10 blur-[130px] rounded-full pointer-events-none -z-20 mix-blend-screen"></div>

    <!-- KURSOR SHURIKEN TARGET -->
    <div id="cursor-dot" class="fixed top-0 left-0 w-2 h-2 bg-orange-500 rounded-full pointer-events-none z-[9999] shadow-[0_0_12px_#f97316]"></div>
    
    <div id="cursor-ring" class="fixed top-0 left-0 w-8 h-8 border border-cyan-400/50 rounded-full pointer-events-none z-[9998] flex items-center justify-center mix-blend-screen rotate-45">
        <div class="absolute w-2 h-2 border border-orange-500/60 animate-ping"></div>
    </div>

    <slot />
    
    <script is:inline>
        // SCRIPT KANVAS: CHAKRA EMBERS
        const canvas = document.getElementById('chakra-canvas');
        const ctx = canvas.getContext('2d');
        let width, height, motes = [];

        function initMotes() {
            width = canvas.width = window.innerWidth;
            height = canvas.height = window.innerHeight;
            motes = [];
            for (let i = 0; i < 75; i++) {
                motes.push({
                    x: Math.random() * width,
                    y: Math.random() * height,
                    size: Math.random() * 2.5 + 0.5,
                    speedY: Math.random() * 0.8 + 0.3,
                    speedX: (Math.random() - 0.5) * 0.5,
                    opacity: Math.random() * 0.7 + 0.2,
                    color: Math.random() > 0.4 ? '#f97316' : (Math.random() > 0.3 ? '#22d3ee' : '#ef4444')
                });
            }
        }

        function animateMotes() {
            ctx.clearRect(0, 0, width, height);
            for (let m of motes) {
                m.y -= m.speedY;
                m.x += m.speedX;
                if (m.y < 0) { m.y = height; m.x = Math.random() * width; }
                if (m.x < 0) m.x = width;
                if (m.x > width) m.x = 0;

                ctx.beginPath();
                ctx.fillStyle = m.color;
                ctx.globalAlpha = m.opacity;
                ctx.shadowBlur = 8;
                ctx.shadowColor = m.color;
                ctx.arc(m.x, m.y, m.size, 0, Math.PI * 2);
                ctx.fill();
            }
            requestAnimationFrame(animateMotes);
        }

        window.addEventListener('resize', initMotes);
        initMotes();
        animateMotes();
        
        if (typeof gsap !== 'undefined') {
            gsap.registerPlugin(ScrollTrigger);

            const dot = document.getElementById('cursor-dot');
            const ring = document.getElementById('cursor-ring');

            window.addEventListener('mousemove', (e) => {
                gsap.to(dot, { x: e.clientX - 4, y: e.clientY - 4, duration: 0 });
                gsap.to(ring, { x: e.clientX - 16, y: e.clientY - 16, duration: 0.15, ease: "power2.out" });
            });

            // Gunakan file hover.mp3 yang sama (efek suara swish/katana jika ada)
            const hoverSound = new Howl({ src: ['/hover.mp3'], volume: 0.15 });

            const addHoverEffect = () => {
                const clickables = document.querySelectorAll('a, button, #chakra-core, .group');
                clickables.forEach(el => {
                    el.addEventListener('mouseenter', () => {
                        if(hoverSound.state() === 'loaded') hoverSound.play(); 
                        gsap.to(ring, { scale: 1.5, borderColor: '#f97316', rotation: 90, duration: 0.2 });
                        gsap.to(dot, { scale: 1.8, backgroundColor: '#22d3ee', duration: 0.2 });
                    });
                    el.addEventListener('mouseleave', () => {
                        gsap.to(ring, { scale: 1, borderColor: 'rgba(34, 211, 238, 0.5)', rotation: 45, duration: 0.2 });
                        gsap.to(dot, { scale: 1, backgroundColor: '#f97316', duration: 0.2 });
                    });
                });
            };
            setTimeout(addHoverEffect, 1000); 
        }
    </script>
</body>
</html>