---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import EarthquakeProject from '../components/EarthquakeProject.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
---

<Layout title="Low-Latency Architect - IJM.CORE">
    <Navbar />
    
    <MusicPlayer />

    <main class="max-w-7xl mx-auto px-6 overflow-hidden">
        
        <Hero />

        <!-- Seksi Global Telemetry Feed -->
        <section id="observatory" class="py-24 reveal-scroll mt-16 relative z-10 border-t border-emerald-500/20">
            
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start mb-12">
                <div class="lg:col-span-5 flex flex-col justify-center">
                    <div class="flex items-center gap-3 mb-3">
                        <span class="text-emerald-500 font-mono text-lg font-bold">01.</span>
                        <span class="text-[10px] font-mono text-cyan-400 tracking-[0.2em] uppercase bg-cyan-950/60 px-2.5 py-1 rounded border border-cyan-500/30">
                            DATA_PIPELINE_FEED
                        </span>
                    </div>
                    <h2 class="text-3xl sm:text-5xl font-bold text-white tracking-tighter drop-shadow-[0_0_15px_rgba(16,185,129,0.3)]">
                        Real-Time Seismological Feed
                    </h2>
                </div>

                <div class="lg:col-span-7 bg-[#080d1a]/60 backdrop-blur-md p-6 rounded-2xl border border-emerald-500/20 flex flex-col sm:flex-row gap-6 items-center justify-between shadow-lg">
                    <p class="text-xs sm:text-sm text-zinc-300 font-light leading-relaxed">
                        Infrastruktur pemantauan global memproses aktivitas seismik bumi secara <span class="text-emerald-400 font-medium">real-time</span> dengan latensi minimal. Data mentah USGS diubah menjadi koordinat radar interaktif.
                    </p>
                    <div class="font-mono text-[10px] text-zinc-400 bg-[#030508] p-3 rounded border border-emerald-500/20 shrink-0 w-full sm:w-auto text-center sm:text-left shadow-inner">
                        <span class="text-emerald-400">fetch</span>('.../geojson')<br/>
                        &nbsp;.then(res => res.<span class="text-cyan-400">json</span>())
                    </div>
                </div>
            </div>

            <!-- Map Meja Komando Full-Width -->
            <div class="w-full h-[450px] lg:h-[550px] rounded-2xl overflow-hidden shadow-[0_0_40px_rgba(16,185,129,0.1)] border border-emerald-500/30 relative">
                <EarthquakeProject />
            </div>

        </section>

    </main>

    <Footer />
</Layout>

<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        if (typeof window.gsap !== 'undefined') {
            window.gsap.registerPlugin(window.ScrollTrigger);
            
            const tl = window.gsap.timeline();
            tl.from(".header-nav", { y: -30, opacity: 0, duration: 1, ease: "power2.out" })
              .from(".hero-item", { y: 30, opacity: 0, duration: 1, stagger: 0.15, ease: "power3.out" }, "-=0.5"); 
        }
    });
</script>