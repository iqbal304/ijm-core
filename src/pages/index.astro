---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import EarthquakeProject from '../components/EarthquakeProject.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
---

<Layout title="Web Portofolio - Iqbal Jabar Marjan">
    <Navbar />
    
    <MusicPlayer />

    <main class="max-w-7xl mx-auto px-6 overflow-hidden">
        
        <Hero />

        <section id="observatory" class="py-20 reveal-scroll mt-20 relative z-10 border-t border-white/10">
            <div class="flex items-center gap-4 mb-12">
                <span class="text-sky-400 font-mono text-lg font-bold">01.</span>
                <h2 class="text-2xl md:text-4xl font-bold text-white tracking-tighter">Observatorium Seismik</h2>
                <div class="h-px bg-white/10 grow max-w-sm ml-4 hidden sm:block"></div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                
                <div class="lg:col-span-1 flex flex-col gap-6">
                    <div class="bg-white/5 border border-white/10 p-6 xl:p-8 rounded-2xl backdrop-blur-md h-full flex flex-col justify-between shadow-[0_0_30px_rgba(0,0,0,0.5)]">
                        <div>
                            <div class="text-[9px] font-mono text-violet-400 tracking-[0.2em] mb-4 flex items-center gap-2">
                                <span class="w-1.5 h-1.5 bg-violet-500 rounded-full animate-pulse"></span>
                                DATA_STREAM_ACTIVE
                            </div>
                            <h3 class="text-xl md:text-2xl font-bold text-white mb-3">Integrasi API USGS</h3>
                            <p class="text-xs md:text-sm text-zinc-400 font-light leading-relaxed mb-6">
                                Contoh nyata bagaimana backend memproses data mentah. Skrip ini menarik data gempa terbaru secara global, mem-parsing GeoJSON, dan merendernya ke visual secara langsung.
                            </p>
                        </div>
                        
                        <div class="font-mono text-[10px] md:text-xs text-zinc-500 bg-[#02000a] p-3 md:p-4 rounded-xl border border-white/5 overflow-x-auto">
                            <span class="text-sky-400">fetch</span>('https://earthquake.../geojson')<br/>
                            &nbsp;&nbsp;.then(res => res.<span class="text-violet-400">json</span>())<br/>
                            &nbsp;&nbsp;.then(data => renderMap(data));
                        </div>
                    </div>
                </div>

                <div class="lg:col-span-2 relative">
                    <EarthquakeProject />
                </div>

            </div>
        </section>

    </main>

    <Footer />
</Layout>

<script>
    // Memberitahu TypeScript bahwa GSAP sudah diload dari CDN
    declare const gsap: any;
    declare const ScrollTrigger: any;

    document.addEventListener("DOMContentLoaded", () => {
        gsap.registerPlugin(ScrollTrigger);
        
        // Animasi masuk untuk Navbar dan Hero
        const tl = gsap.timeline();
        tl.from(".header-nav", { y: -30, opacity: 0, duration: 1, ease: "power2.out" })
          .from(".hero-item", { y: 30, opacity: 0, duration: 1, stagger: 0.15, ease: "power3.out" }, "-=0.5"); 
    });
</script>