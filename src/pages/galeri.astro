---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Galeri | Spektrum Visual">
    <Navbar />

    <main class="max-w-7xl mx-auto px-6 pt-24 pb-20 min-h-screen">
        
        <div class="mb-16 reveal-scroll">
            <h1 class="text-4xl md:text-6xl font-extrabold text-white tracking-tighter mb-4 text-glow-sky">
                SPEKTRUM_VISUAL.
            </h1>
            <p class="text-zinc-400 font-mono text-sm border-l-2 border-sky-500 pl-4">
                > Arsip memori dan karya visual yang tertangkap di luar angkasa.
            </p>
        </div>

        <div class="columns-1 sm:columns-2 md:columns-3 gap-6 space-y-6 reveal-scroll">
            
            <div class="relative group rounded-2xl overflow-hidden border border-white/10 bg-white/5 break-inside-avoid">
                <div class="absolute inset-0 bg-violet-500/20 mix-blend-overlay opacity-0 group-hover:opacity-100 transition-opacity z-10 duration-500"></div>
                <img src="/foto-iqbal.jpg" alt="Gallery Image 1" class="w-full h-auto grayscale-50 group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
                <div class="absolute bottom-0 left-0 w-full p-4 bg-linear-to-t from-black/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity z-20">
                    <p class="font-mono text-[10px] text-sky-400 tracking-widest">LOG_001</p>
                    <p class="text-white text-sm font-medium">Di balik layar</p>
                </div>
            </div>

            <div class="relative group rounded-2xl overflow-hidden border border-white/10 bg-zinc-900 p-8 flex items-center justify-center min-h-75 break-inside-avoid hover:border-violet-500/50 transition-colors">
                <p class="font-serif italic text-xl text-zinc-300 text-center leading-relaxed">
                    "Terkadang, <span class="text-sky-400">desain terbaik</span> adalah desain yang tidak terlihat."
                </p>
            </div>

            <div class="relative group rounded-2xl overflow-hidden border border-white/10 bg-white/5 break-inside-avoid min-h-62.5 flex items-center justify-center">
                <p class="text-zinc-600 font-mono text-[10px] uppercase tracking-widest animate-pulse">Awaiting Data...</p>
            </div>

        </div>

    </main>

    <Footer />
</Layout>

<script>
    declare const gsap: any;
    declare const ScrollTrigger: any;

    document.addEventListener("DOMContentLoaded", () => {
        gsap.registerPlugin(ScrollTrigger);
        // Memastikan animasi hanya jalan jika elemen ada
        gsap.from(".reveal-scroll", {
            y: 50, opacity: 0, duration: 1, stagger: 0.2, ease: "power3.out"
        });
    });
</script>