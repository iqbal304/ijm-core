---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Data Vault Archives | IJM.CORE">
    <Navbar />

    <main class="max-w-7xl mx-auto px-6 pt-32 pb-24 min-h-screen">
        
        <div class="mb-16 reveal-scroll">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded bg-emerald-950/50 border border-emerald-500/30 text-emerald-400 font-mono text-xs mb-4">
                <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse"></span>
                DATA VAULT ARCHIVES // IJM.CORE
            </div>
            <h1 class="text-5xl md:text-7xl font-extrabold text-white tracking-tighter mb-4 text-glow-green">
                SYSTEM_LOGS.
            </h1>
            <p class="text-zinc-300 font-mono text-sm border-l-2 border-emerald-500 pl-4 max-w-2xl">
                > Repositori arsitektur sistem, catatan latensi, dan eksekusi antarmuka berskala tinggi.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 reveal-scroll">
            
            <!-- KIRI (7 Kolom): Foto Utama -->
            <div class="lg:col-span-7 relative group rounded-2xl overflow-hidden border border-emerald-500/30 bg-[#080d1a] min-h-[450px] sm:min-h-[550px] flex flex-col justify-end p-8 shadow-2xl">
                <div class="absolute inset-0 bg-gradient-to-t from-[#030508] via-[#030508]/30 to-transparent z-10"></div>
                <img src="/foto-iqbal.jpg" alt="Iqbal Jabar" class="absolute inset-0 w-full h-full object-cover grayscale-[20%] group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
                
                <div class="relative z-20 max-w-xl">
                    <span class="px-3 py-1 rounded bg-emerald-500/20 border border-emerald-500/40 text-emerald-300 font-mono text-[10px] uppercase tracking-widest mb-3 inline-block backdrop-blur-md">
                        LOG_001 // SYSTEM ARCHITECT
                    </span>
                    <h3 class="text-2xl sm:text-4xl font-bold text-white mb-2">Iqbal Jabar Marjan</h3>
                    <p class="text-zinc-300 text-xs sm:text-sm leading-relaxed">
                        Fokus pada ketahanan sistem (high-availability), efisiensi kueri database di Backend, serta UI analitik super cepat di Frontend.
                    </p>
                </div>
            </div>

            <!-- KANAN (5 Kolom): 2 Kartu Berjajar Vertikal -->
            <div class="lg:col-span-5 flex flex-col gap-8 justify-between">
                
                <!-- Kartu Atas: Filosofi HFT -->
                <div class="relative group rounded-2xl overflow-hidden border border-emerald-500/30 bg-[#080d1a]/80 backdrop-blur-xl p-8 flex flex-col justify-center grow hover:border-cyan-400/60 transition-colors shadow-lg">
                    <div class="w-8 h-8 rounded bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center mb-6 text-emerald-400 font-mono text-lg">></div>
                    <p class="font-sans text-lg text-zinc-200 leading-relaxed mb-6 font-light">
                        "Dalam sistem berskala besar, <span class="text-cyan-400 font-semibold">latensi</span> adalah musuh utama. Kami membangun infrastruktur yang tidak hanya indah di mata, namun tangguh saat memproses <span class="text-emerald-400 font-semibold">jutaan data</span> secara serentak."
                    </p>
                    <div class="flex items-center justify-between border-t border-white/10 pt-4 text-[10px] font-mono text-zinc-500">
                        <span>ENGINEERING STANDARDS</span>
                        <span class="text-emerald-400">>_ IJM.CORE</span>
                    </div>
                </div>

                <!-- Kartu Bawah: Slot Log -->
                <div class="relative group rounded-2xl overflow-hidden border border-emerald-500/20 bg-[#080d1a]/40 p-8 border-dashed hover:border-emerald-500/50 transition-all flex flex-col items-center justify-center text-center h-48">
                    <div class="w-3 h-3 bg-cyan-400/60 rounded-full animate-ping mb-3"></div>
                    <p class="text-zinc-300 font-mono text-xs uppercase tracking-widest font-semibold mb-1">
                        Menunggu Aliran Data Baru...
                    </p>
                    <span class="text-[9px] font-mono text-zinc-500">[SLOT_LOG_TERSEDIA]</span>
                </div>

            </div>

        </div>

    </main>

    <Footer />
</Layout>

<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        if (typeof window.gsap !== 'undefined') {
            window.gsap.registerPlugin(window.ScrollTrigger);
            window.gsap.from(".reveal-scroll", {
                y: 50, opacity: 0, duration: 1, stagger: 0.2, ease: "power3.out"
            });
        }
    });
</script>