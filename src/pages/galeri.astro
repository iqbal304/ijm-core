---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Arsip Istana Langit | IJM.CORE">
    <Navbar />

    <main class="max-w-7xl mx-auto px-6 pt-32 pb-24 min-h-screen">
        
        <!-- Header Galeri -->
        <div class="mb-16 reveal-scroll">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-950/50 border border-emerald-500/30 text-emerald-400 font-mono text-xs mb-4">
                <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse"></span>
                ARSISTUR & MEMORI // IJM.CORE
            </div>
            <h1 class="text-5xl md:text-7xl font-extrabold text-white tracking-tighter mb-4 text-glow-cyan">
                SPEKTRUM_LAPUTA.
            </h1>
            <p class="text-zinc-300 font-mono text-sm border-l-2 border-emerald-500 pl-4 max-w-2xl">
                > Serpihan memori, jejak kode, dan estetika peradaban yang tertinggal di atas awan.
            </p>
        </div>

        <!-- LAYOUT BARU: Ghibli Artbook Grid (12-Column Editorial Layout) -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 reveal-scroll">
            
            <!-- KIRI (7 Kolom): Foto Utama Raksasa -->
            <div class="lg:col-span-7 relative group rounded-3xl overflow-hidden border border-emerald-500/30 bg-[#0a1118] min-h-[450px] sm:min-h-[550px] flex flex-col justify-end p-8 shadow-2xl">
                <div class="absolute inset-0 bg-gradient-to-t from-[#070b12] via-[#070b12]/30 to-transparent z-10"></div>
                <img src="/foto-iqbal.jpg" alt="Iqbal Jabar" class="absolute inset-0 w-full h-full object-cover grayscale-[20%] group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
                
                <div class="relative z-20 max-w-xl">
                    <span class="px-3 py-1 rounded-full bg-cyan-500/20 border border-cyan-400/40 text-cyan-300 font-mono text-[10px] uppercase tracking-widest mb-3 inline-block backdrop-blur-md">
                        PRASASTI_001 // LEAD ARCHITECT
                    </span>
                    <h3 class="text-2xl sm:text-4xl font-bold text-white mb-2">Iqbal Jabar Marjan</h3>
                    <p class="text-zinc-300 text-xs sm:text-sm leading-relaxed">
                        Membangun jembatan antara logika sistem yang rumit (*Backend*) dengan antarmuka yang ramah dan memukau bagi manusia (*Frontend*).
                    </p>
                </div>
            </div>

            <!-- KANAN (5 Kolom): 2 Kartu Berjajar Vertikal -->
            <div class="lg:col-span-5 flex flex-col gap-8 justify-between">
                
                <!-- Kartu Atas: Kutipan Filosofis Laputa -->
                <div class="relative group rounded-3xl overflow-hidden border border-emerald-500/30 bg-[#0a1118]/80 backdrop-blur-xl p-8 flex flex-col justify-center grow hover:border-cyan-400/60 transition-colors shadow-lg">
                    <div class="w-8 h-8 rounded-full bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center mb-6 text-emerald-400 font-serif text-lg">"</div>
                    <p class="font-serif italic text-lg text-zinc-200 leading-relaxed mb-6">
                        "Sebanyak apapun kode yang kau tulis, atau secerdas apapun <span class="text-cyan-400 font-semibold not-italic">logika sistemmu</span>, kita tidak bisa bertahan tanpa terhubung dengan <span class="text-emerald-400 font-semibold not-italic">keindahan alam</span>."
                    </p>
                    <div class="flex items-center justify-between border-t border-white/10 pt-4 text-[10px] font-mono text-zinc-500">
                        <span>FILOSOFI DESAIN</span>
                        <span class="text-cyan-400">>_ IJM.CORE</span>
                    </div>
                </div>

                <!-- Kartu Bawah: Slot Memori / Karya Berikutnya -->
                <div class="relative group rounded-3xl overflow-hidden border border-emerald-500/20 bg-[#0a1118]/40 p-8 border-dashed hover:border-emerald-500/50 transition-all flex flex-col items-center justify-center text-center h-48">
                    <div class="w-3 h-3 bg-amber-400/60 rounded-full animate-ping mb-3"></div>
                    <p class="text-zinc-300 font-mono text-xs uppercase tracking-widest font-semibold mb-1">
                        Menunggu Transmisi Memori...
                    </p>
                    <span class="text-[9px] font-mono text-zinc-500">[SLOT_KARYA_TERSEDIA]</span>
                </div>

            </div>

        </div>

    </main>

    <Footer />
</Layout>

<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        if (typeof window.gsap !== 'undefined') {
            window.gsap.registerPlugin(window.ScrollTrigger);
            window.gsap.from(".reveal-scroll", {
                y: 50, opacity: 0, duration: 1, stagger: 0.2, ease: "power3.out"
            });
        }
    });
</script>