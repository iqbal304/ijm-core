---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Arsip Bayt al-Hikmah | IJM.CORE">
    <Navbar />

    <main class="max-w-7xl mx-auto px-6 pt-24 pb-20 min-h-screen">
        
        <div class="mb-16 reveal-scroll">
            <h1 class="text-4xl md:text-6xl font-extrabold text-white tracking-tighter mb-4 text-glow-amber">
                BAYT_AL_HIKMAH.
            </h1>
            <p class="text-zinc-300 font-mono text-sm border-l-2 border-amber-500 pl-4">
                > Rumah Kebijaksanaan: Arsip kode, filosofi geometri, dan mahakarya digital.
            </p>
        </div>

        <div class="columns-1 sm:columns-2 md:columns-3 gap-6 space-y-6 reveal-scroll">
            
            <div class="relative group rounded-2xl overflow-hidden border border-amber-500/20 bg-[#080d1a]/60 break-inside-avoid shadow-lg">
                <div class="absolute inset-0 bg-gradient-to-t from-amber-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity z-10 duration-500"></div>
                <img src="/foto-iqbal.jpg" alt="Iqbal Jabar" class="w-full h-auto grayscale-[30%] group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
                <div class="absolute bottom-0 left-0 w-full p-4 bg-gradient-to-t from-[#060913] via-[#060913]/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity z-20">
                    <p class="font-mono text-[10px] text-amber-400 tracking-widest">KITAB_001</p>
                    <p class="text-white text-sm font-medium">Arsitek Algoritma</p>
                </div>
            </div>

            <div class="relative group rounded-2xl overflow-hidden border border-amber-500/30 bg-[#080d1a] p-8 flex flex-col items-center justify-center min-h-75 break-inside-avoid hover:border-teal-400/60 transition-colors shadow-[inset_0_0_20px_rgba(245,158,11,0.05)]">
                <div class="w-8 h-8 rounded-full bg-amber-500/10 border border-amber-500/30 flex items-center justify-center mb-6 text-amber-400 font-serif">"</div>
                <p class="font-serif italic text-lg md:text-xl text-zinc-200 text-center leading-relaxed">
                    "Semua kerumitan dalam dunia komputasi modern berakar dari kesederhanaan <span class="text-amber-400 font-semibold">Aljabar</span> dan keharmonisan <span class="text-teal-400 font-semibold">Geometri</span>."
                </p>
                <span class="text-[9px] font-mono text-zinc-500 tracking-widest uppercase mt-6">— Filosofi Warisan Algoritma</span>
            </div>

            <div class="relative group rounded-2xl overflow-hidden border border-amber-500/15 bg-[#080d1a]/40 break-inside-avoid min-h-62.5 flex flex-col items-center justify-center p-6 border-dashed hover:border-amber-500/40 transition-all">
                <div class="w-3 h-3 bg-teal-400/40 rounded-full animate-ping mb-3"></div>
                <p class="text-zinc-400 font-mono text-[10px] uppercase tracking-widest text-center">Menunggu Transmisi Kitab Baru...</p>
                <span class="text-[8px] font-mono text-zinc-600 mt-1">[SLOT_ARSIP_TERSEDIA]</span>
            </div>

        </div>

    </main>

    <Footer />
</Layout>

<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        if (typeof window.gsap !== 'undefined') {
            window.gsap.registerPlugin(window.ScrollTrigger);
            window.gsap.from(".reveal-scroll", {
                y: 50, opacity: 0, duration: 1, stagger: 0.2, ease: "power3.out"
            });
        }
    });
</script>