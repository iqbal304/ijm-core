---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Arsip Istana Langit | Galeri Laputa">
    <Navbar />

    <main class="max-w-7xl mx-auto px-6 pt-24 pb-20 min-h-screen">
        
        <div class="mb-16 reveal-scroll">
            <h1 class="text-4xl md:text-6xl font-extrabold text-white tracking-tighter mb-4 text-glow-cyan">
                ARSITEKTUR & MEMORI
            </h1>
            <p class="text-zinc-300 font-mono text-sm border-l-2 border-emerald-500 pl-4">
                > Serpihan memori, jejak kode, dan estetika peradaban yang tertinggal di atas awan.
            </p>
        </div>

        <div class="columns-1 sm:columns-2 md:columns-3 gap-6 space-y-6 reveal-scroll">
            
            <!-- Memori 1: Penemuan Istana Langit -->
            <div class="relative group rounded-2xl overflow-hidden border border-emerald-500/20 bg-[#0a1118]/60 break-inside-avoid shadow-lg">
                <div class="absolute inset-0 bg-gradient-to-t from-cyan-900/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity z-10 duration-500"></div>
                <img src="/504631.jpg" alt="Laputa Memori 1" class="w-full h-auto grayscale-[30%] group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
                <div class="absolute bottom-0 left-0 w-full p-5 bg-gradient-to-t from-[#070b12] via-[#070b12]/90 to-transparent opacity-0 group-hover:opacity-100 transition-opacity z-20">
                    <p class="font-mono text-[10px] text-cyan-400 tracking-widest">MEMORI 001</p>
                    <p class="text-white text-sm font-medium mt-1">Penemuan Istana Langit</p>
                </div>
            </div>

            <!-- Memori 2: Kota di Atas Awan -->
            <div class="relative group rounded-2xl overflow-hidden border border-emerald-500/20 bg-[#0a1118]/60 break-inside-avoid shadow-lg">
                <div class="absolute inset-0 bg-gradient-to-t from-emerald-900/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity z-10 duration-500"></div>
                <img src="/1031480.jpg" alt="Laputa Memori 2" class="w-full h-auto grayscale-[30%] group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
                <div class="absolute bottom-0 left-0 w-full p-5 bg-gradient-to-t from-[#070b12] via-[#070b12]/90 to-transparent opacity-0 group-hover:opacity-100 transition-opacity z-20">
                    <p class="font-mono text-[10px] text-emerald-400 tracking-widest">MEMORI 002</p>
                    <p class="text-white text-sm font-medium mt-1">Kota di Atas Awan</p>
                </div>
            </div>

            <!-- Kartu Kutipan Filosofis Ghibli (Laputa Quote) -->
            <div class="relative group rounded-2xl overflow-hidden border border-emerald-500/30 bg-[#0a1118] p-8 flex flex-col items-center justify-center min-h-[250px] break-inside-avoid hover:border-cyan-400/60 transition-colors shadow-[inset_0_0_20px_rgba(16,185,129,0.05)]">
                <div class="w-8 h-8 rounded-full bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center mb-6 text-emerald-400 font-serif">"</div>
                <p class="font-serif italic text-lg md:text-xl text-zinc-200 text-center leading-relaxed">
                    "Sebanyak apapun kode yang kau tulis, atau secerdas apapun <span class="text-cyan-400 font-semibold not-italic">logika sistemmu</span>, kita tidak bisa bertahan tanpa terhubung dengan <span class="text-emerald-400 font-semibold not-italic">keindahan alam</span>."
                </p>
                <span class="text-[9px] font-mono text-zinc-500 tracking-widest uppercase mt-6">— Adaptasi Filosofi Laputa</span>
            </div>

            <!-- Memori 3: Menembus Badai Aether -->
            <div class="relative group rounded-2xl overflow-hidden border border-emerald-500/20 bg-[#0a1118]/60 break-inside-avoid shadow-lg">
                <div class="absolute inset-0 bg-gradient-to-t from-cyan-900/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity z-10 duration-500"></div>
                <img src="/8472.jpg" alt="Laputa Memori 3" class="w-full h-auto grayscale-[30%] group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
                <div class="absolute bottom-0 left-0 w-full p-5 bg-gradient-to-t from-[#070b12] via-[#070b12]/90 to-transparent opacity-0 group-hover:opacity-100 transition-opacity z-20">
                    <p class="font-mono text-[10px] text-cyan-400 tracking-widest">MEMORI 003</p>
                    <p class="text-white text-sm font-medium mt-1">Menembus Badai Aether</p>
                </div>
            </div>

            <!-- Memori 4: Penjaga Taman Kuno -->
            <div class="relative group rounded-2xl overflow-hidden border border-emerald-500/20 bg-[#0a1118]/60 break-inside-avoid shadow-lg">
                <div class="absolute inset-0 bg-gradient-to-t from-emerald-900/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity z-10 duration-500"></div>
                <img src="/828255.png" alt="Laputa Memori 4" class="w-full h-auto grayscale-[30%] group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
                <div class="absolute bottom-0 left-0 w-full p-5 bg-gradient-to-t from-[#070b12] via-[#070b12]/90 to-transparent opacity-0 group-hover:opacity-100 transition-opacity z-20">
                    <p class="font-mono text-[10px] text-emerald-400 tracking-widest">MEMORI 004</p>
                    <p class="text-white text-sm font-medium mt-1">Penjaga Taman Kuno</p>
                </div>
            </div>

        </div>

    </main>

    <Footer />
</Layout>

<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        if (typeof window.gsap !== 'undefined') {
            window.gsap.registerPlugin(window.ScrollTrigger);
            window.gsap.from(".reveal-scroll", {
                y: 50, opacity: 0, duration: 1.2, stagger: 0.2, ease: "power3.out"
            });
        }
    });
</script>